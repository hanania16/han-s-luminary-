generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id        String   @id
  title     String
  albumId   String
  url       String
  thumb     String
  date      String
  tags      String[] @default([])
  likes     Int      @default(0)
  stored    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Album {
  id        String   @id
  name      String
  cover     String
  count     Int      @default(0)
  createdAt DateTime @default(now())
}

model Request {
  id         String    @id
  photoId    String
  photoTitle String
  photoIds   String[]  @default([])
  photoTitles String[] @default([])
  name       String
  from       String
  message    String
  social     String    @default("")
  status     String    @default("pending")
  date       String
  approvedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Message {
  id        String   @id
  name      String
  text      String
  from      String
  date      String
  createdAt DateTime @default(now())
}
